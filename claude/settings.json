{
  "skillOverrides": {
    "frontend-design": "on"
  },
  "disabledMcpjsonServers": [
    "mcp__Adobe_for_creativity",
    "mcp__Notion",
    "mcp__Figma"
  ],
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "taste-skill": {
      "source": {
        "source": "github",
        "repo": "Leonxlnx/taste-skill"
      }
    },
    "awesome-design-md": {
      "source": {
        "source": "github",
        "repo": "VoltAgent/awesome-design-md"
      }
    },
    "npxskillui": {
      "source": {
        "source": "github",
        "repo": "amaancoderx/npxskillui"
      }
    }
  },
  "env": {
    "CLAUDE_AUTO_PUSH_TO_MAIN": "true"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/scope-guard-hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/checkpoint-nudge.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
